# ──────────────────────────────────────────────────────────────────────────────
# ARC Voice Agent — Environment Variables
# Copy this file to .env and fill in your real values.
# ──────────────────────────────────────────────────────────────────────────────

# ── LiveKit Cloud ──────────────────────────────────────────────────────────────
# Get these from https://cloud.livekit.io → your project → Settings → Keys
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=your_livekit_api_key
LIVEKIT_API_SECRET=your_livekit_api_secret

# ── Gemini ────────────────────────────────────────────────────────────────────
# Same key you use for the ARC desktop app
GOOGLE_API_KEY=your_google_api_key

# ── CORS (token server) ────────────────────────────────────────────────────────
# Set this to your Vercel deployment URL in production, e.g.:
#   ALLOWED_ORIGIN=https://your-project.vercel.app
# Leave blank or set to * for local development.
ALLOWED_ORIGIN=*

# ── Populated AFTER you deploy the token server on Railway ────────────────────
# Copy the Railway public URL here, then redeploy your Vercel app.
# (This env var is read by the Next.js frontend, not this service.)
NEXT_PUBLIC_TOKEN_SERVER_URL=https://your-token-server.railway.app
